{
  "name": "clowder-and-crest",
  "version": "2.7.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "check": "npm run check:static && npm run test:logic",
    "check:static": "node scripts/static-check.mjs",
    "clean:test": "rm -rf test/screenshots && mkdir -p test/screenshots",
    "test:logic": "tsx test/logic-regressions.ts",
    "test:smoke": "node test/smoke.mjs",
    "test:explore": "node test/explore.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
