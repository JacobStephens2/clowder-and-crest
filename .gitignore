# Patterns that match both directories AND symlinks (no trailing slash).
# After the 2026-04-08 disk migration, several of these became symlinks
# pointing at /mnt/volume_nyc3_01/jacob/clowder/, and trailing-slash
# patterns only matched real directories — so the symlinks showed up as
# untracked files until the slashes were dropped.
node_modules
dist/
android/.gradle/
android/build/
android/app/build
android/capacitor-cordova-android-plugins/build/
android/app/src/main/assets/public/
android/app/src/main/assets/capacitor.config.json
android/app/src/main/assets/capacitor.plugins.json
*.apk
.DS_Store
screenshots/
todo/music/
todo/pixel_art/
todo/art/portraits/
sound_effects/
todo/.stfolder/
todo/*-capture.md
todo/ideas/.DS_Store
.env
.env.local
*.env
test/screenshots/

# Syncthing folder marker
.stfolder/
